# Example proxy config. Copy to `proxy.toml` and fill in real values.
# Anything left unset falls back to env vars, then built-in defaults
# (see REFERENCE.md for the full resolution order).
#
# Env vars always win over this file, so you can keep secrets in the
# environment and use this file for non-secret defaults:
#
#     UPSTREAM_API_KEY=... cargo run
#
# What you can set here:
#   listen_addr          — e.g. "0.0.0.0:8085" (default)
#   upstream_base_url    — required, e.g. "https://api.openai.com"
#   upstream_api_key     — required, sent as Bearer to upstream
#   upstream_path        — default "/v1/responses"
#   request_timeout_secs — default 600 (10 min)
#   reasoning_effort     — global default; overridden by [reasoning]
#                          (see the [reasoning] table below)
#   prompt_caching       — opt-in OpenAI prompt-caching controls
#                          (see the [prompt_caching] table below)

# [prompt_caching]
# enabled = false
# cache_key = "my-app"
#
# When `enabled = true`, Anthropic `cache_control: {type: "ephemeral"}`
# markers on user/system text and image blocks are translated into
# OpenAI `prompt_cache_breakpoint` markers on the outbound
# `/v1/responses` request. Endpoints that don't understand these fields
# (Ollama, OpenRouter, vLLM, etc.) silently ignore them, so the change
# is safe for non-OpenAI upstreams. Leave `enabled = false` (the
# default) if your upstream does not support OpenAI prompt caching.
#
# `cache_key` is optional. If set, it is forwarded as
# `prompt_cache_key` to help the upstream route similar prompt prefixes
# to the same cache.

# ─── Example: NVIDIA OpenAI-compatible ──────────────────────────────────
upstream_base_url = "https://integrate.api.nvidia.com/"
upstream_api_key  = "your-nvapi-key-here"
request_timeout_secs = 600

# ─── Example: Airia gateway (openai-compatible) ─────────────────────────
# Uncomment and swap into the active slot to test against Airia instead.
# The gateway picks the model server-side; do NOT set one here.
# upstream_base_url = "https://prodaus.gateway.airia.ai"
# upstream_api_key  = "your-airia-key-here"
# request_timeout_secs = 600

# ─── Per-model reasoning effort ─────────────────────────────────────────
# The proxy targets the /v1/responses endpoint, which is more lenient
# about combining reasoning with function tools than /v1/chat/completions
# is on some gateways (notably airia). As a result, models that used to
# require "none" for tool use can now run with real reasoning effort.
# The proxy picks the effort to send per request using this resolution
# chain:
#   1. `reasoning.models[req.model]` — exact match (highest priority)
#   2. `reasoning.default` — fallback for any model not in the map
#   3. The legacy top-level `reasoning_effort` field
#   4. The built-in default ("none")
#
# Example: gpt-5.6-luna used to require "none" for tool use on
# chat-completions; on /v1/responses it accepts higher effort, so
# bumping it to "medium" lets it reason while still calling tools.
# gpt-5.4-mini can do high reasoning.
#
# Valid values: "none" | "low" | "medium" | "high" | "xhigh" | "max".
# ("xhigh" and "max" are accepted by /v1/responses but not by
# /v1/chat/completions — use the former.)
#
# [reasoning]
# default = "none"
#
# [reasoning.models]
# "gpt-5.4-mini" = "high"
# "gpt-5.6-luna"  = "medium"

# ─── Model name aliases ─────────────────────────────────────────────────
# Map inbound model names to upstream model names. Useful when the
# client (e.g. Claude Code subagents) requests Anthropic model names
# like `claude-sonnet-5` or `claude-haiku-4-5` that the gateway
# doesn't recognize, and you want those requests routed to a real
# upstream model like `gpt-5.4-mini`.
#
# Without this table, requests for an unknown model go to the
# gateway with that name verbatim and 400 with "The requested model
# is not supported for the selected provider."
#
# Lookup is exact-string match; no globs or fallbacks. If a model
# isn't in the map, the proxy passes the name through unchanged,
# so deployments that don't need aliases need no config here.
#
# Note: when an alias fires, the proxy also uses the *resolved*
# upstream name for the per-model reasoning_effort lookup. So
# aliasing `claude-sonnet-5` → `gpt-5.4-mini` AND setting a
# reasoning entry for `gpt-5.4-mini` means subagent requests get
# the right effort too.
#
# `default_model` is a safety net: if the upstream rejects an
# aliased or passed-through model with a "not supported" / "not
# found" error, the proxy retries the request once with this
# model. Every fallback is logged at WARN. Leave unset (or omit
# the key) to disable — the upstream rejection will then pass
# through to the client unchanged.
#
# [model_aliases]
# default_model = "gpt-4o-mini"
#
# [model_aliases.map]
# "claude-opus-4-8"  = "gpt-5.6-luna"
# "claude-sonnet-5"  = "gpt-5.4-mini"
# "claude-haiku-4-5" = "gpt-4o-mini"
