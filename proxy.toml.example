# Example proxy configuration. Copy to `proxy.toml` and edit.
# Environment variables take precedence over any value set here.

# Address the proxy listens on.
listen_addr = "0.0.0.0:8085"

# OpenAI-compatible upstream. Required.
upstream_base_url = "https://api.openai.com"

# Bearer token for the upstream. Required.
upstream_api_key = "sk-..."

# Path the proxy appends to `upstream_base_url`. Defaults to
# `/v1/chat/completions`. Change this if your upstream exposes the
# endpoint at a different path.
upstream_path = "/v1/chat/completions"

# Per-request timeout in seconds. Defaults to 600 (10 minutes), which
# matches Anthropic's own `--max-time 600` for `/v1/messages`.
request_timeout_secs = 600
